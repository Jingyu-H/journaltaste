                      三级管道 DOI → CrossRef → OpenAlex · 参考文献 3× 加权 · 仅统计期刊来源 · <a href="https://openalex.org" target="_blank" rel="noopener noreferrer" className="text-teal-500 hover:underline">OpenAlex</a> + <a href="https://www.crossref.org" target="_blank" rel="noopener noreferrer" className="text-teal-500 hover:underline">CrossRef</a>
                    </p>
                  </motion.div>
                )}
              </AnimatePresence>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
}
