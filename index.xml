  '#047857','#a78bfa','#0369a1','#d97706','#b91c1c'
];
const YR = '2024-2026';
const YR_L = '2024–2026';
const CONF = c => c > 0.15 ? ['强匹配','bg-emerald-50 text-emerald-700 border border-emerald-200']
  : c > 0.07 ? ['中匹配','bg-amber-50 text-amber-700 border border-amber-200']
  : ['弱匹配','bg-gray-100 text-gray-500 border border-gray-200'];
const RANK_CLR = ['from-amber-400 to-amber-500','from-gray-300 to-gray-400','from-orange-300 to-orange-400'];

const MAILTO = 'mailto=journaltaste@example.com';

/* ─── 引文分割 ─── */
const splitReferences = (raw) => {
  const text = raw.replace(/\r\n/g, '\n').trim();
  const numberedPattern = /(?:^|\n)\s*(?:\[\d+\]|\(\d+\)|\d+[\.\)])\s/;
  if (numberedPattern.test(text)) {
    const parts = text.split(/(?=(?:^|\n)\s*(?:\[\d+\]|\(\d+\)|\d+[\.\)])\s)/m)
      .map(s => s.trim()).filter(s => s.length > 10);
    if (parts.length > 1) return parts;
  }
  const byPara = text.split(/\n\s*\n/).map(s => s.trim()).filter(s => s.length > 10);
  if (byPara.length > 1) return byPara;
  const byLine = text.split(/\n/).map(s => s.trim()).filter(s => s.length > 10);
  if (byLine.length > 1) return byLine;
  return [text];
};

/* ─── 预处理单条引文 ─── */
const preprocessEntry = (raw) => {
  let t = raw.replace(/\r\n/g, '\n');
  t = t.replace(/\n/g, ' ').replace(/\s{2,}/g, ' ');
  try { t = decodeURIComponent(t); } catch (_) {}
  t = t.replace(/https?:\/\/(dx\.)?doi\.org\//gi, '');
  return t.trim();
};

/* ─── 提取 DOI ─── */
const extractDOIs = (text) => {
  const m = text.match(/10\.\d{4,9}\/[^\s,;}\]"')\u4e00-\u9fff]+/gi) || [];
  const cleaned = m.map(d => d.replace(/[\.,;:\)\]}>]+$/, ''));
  return [...new Set(cleaned)];
};

/* ─── 提取搜索标题 ─── */
const extractTitleQuery = (ref) => {
  let c = ref.replace(/^\s*(?:\[\d+\]|\(\d+\)|\d+[\.\)])\s*/, '');
  c = c.replace(/10\.\d{4,9}\/[^\s]+/g, '');
  c = c.replace(/https?:\/\/[^\s]+/g, '');
  c = c.replace(/\b(doi|pp?|vol|no|eds?|et\s+al)[\.:]\s*/gi, '');
  c = c.trim();
  return c.length > 120 ? c.substring(0, 120) : c;
};

/* ─── API helpers ─── */
const fetchOpenAlexByDOI = async (doi) => {
  try { const r = await fetch(`https://api.openalex.org/works/doi:${doi}`); if (r.ok) return await r.json(); } catch (_) {}
  return null;
};
const fetchCrossRefBiblio = async (bibString) => {
  try {
    const r = await fetch(`https://api.crossref.org/works?query.bibliographic=${encodeURIComponent(bibString)}&rows=1&${MAILTO}`);
    if (r.ok) { const data = await r.json(); const items = data?.message?.items; if (items?.length > 0 && items[0].DOI && items[0].score > 40) return items[0].DOI; }
  } catch (_) {}
  return null;
};
const fetchOpenAlexBySearch = async (query) => {
  try {
    const r = await fetch(`https://api.openalex.org/works?search=${encodeURIComponent(query)}&per_page=1`);
    if (r.ok) { const data = await r.json(); if (data.results?.length > 0) return data.results[0]; }
  } catch (_) {}
  return null;
};

const sleep = (ms) => new Promise(r => setTimeout(r, ms));

export default function JournalTaste() {
  const [mode, setMode] = useState('journal');

  /* F1 state */
  const [query, setQuery] = useState('');
  const [suggestions, setSuggestions] = useState([]);
  const [details, setDetails] = useState(null);
  const [kwData, setKwData] = useState([]);
  const [sfData, setSfData] = useState([]);
  const [totalWorks, setTotalWorks] = useState(0);
  const [searching, setSearching] = useState(false);
  const [tab, setTab] = useState('keywords');
  const [step, setStep] = useState('input');
  const [err, setErr] = useState('');
  const [showDrop, setShowDrop] = useState(false);
  const tmr = useRef(null);

  /* F2 state */
  const [dTitle, setDTitle] = useState('');
  const [dRefs, setDRefs] = useState('');
  const [dStep, setDStep] = useState('input');
  const [dRes, setDRes] = useState(null);
  const [dErr, setDErr] = useState('');
  const [dProgress, setDProgress] = useState(0);
  const [dProgressText, setDProgressText] = useState('');
  const [dMatchStats, setDMatchStats] = useState({ exact: 0, crossref: 0, fuzzy: 0, failed: 0 });
  const fileInputRef = useRef(null);

  const fmt = n => n >= 1e6 ? (n/1e6).toFixed(1)+'M' : n >= 1e3 ? (n/1e3).toFixed(1)+'K' : String(n);
  const isBroad = (kw, bl) => { const k = kw.toLowerCase(); return k.length < 3 || bl.some(b => b.includes(k) || k.includes(b)); };

  /* ═══ F1: 期刊图谱 ═══ */
  const doSearch = async q => {
    if (!q || q.length < 2) { setSuggestions([]); return; }
    setSearching(true);
    try {
      const r = await fetch(`https://api.openalex.org/sources?search=${encodeURIComponent(q)}&filter=type:journal&per_page=6&select=id,display_name,issn_l,works_count,host_organization_name`);
      if (r.ok) setSuggestions((await r.json()).results || []);
    } catch {}
    setSearching(false);
  };
  const onInput = v => { setQuery(v); setShowDrop(true); setErr(''); clearTimeout(tmr.current); tmr.current = setTimeout(() => doSearch(v), 400); };

  const analyzeJournal = async src => {
    setSuggestions([]); setShowDrop(false); setQuery(src.display_name);
    setStep('loading'); setErr('');
    const sid = src.id.replace('https://openalex.org/','');
    const base = `https://api.openalex.org/works?filter=primary_location.source.id:${sid},publication_year:${YR}&group_by=`;
    try {
      const [det, kwR, sfR, fdR] = await Promise.all([
        fetch(`https://api.openalex.org/sources/${sid}`).then(r=>r.json()),
        fetch(base+'keywords.id').then(r=>r.json()),
        fetch(base+'primary_topic.subfield.id').then(r=>r.json()),
        fetch(base+'primary_topic.field.id').then(r=>r.json()),
      ]);
      setDetails(det);
      const sfRaw = (sfR.group_by||[]).sort((a,b)=>b.count-a.count).slice(0,15);
      const fdRaw = (fdR.group_by||[]).sort((a,b)=>b.count-a.count);
      const tw = fdRaw.reduce((s,t)=>s+t.count,0); setTotalWorks(tw);
      if (tw < 30) { setErr(`该期刊在 ${YR_L} 仅有 ${tw} 篇论文，样本不足。`); setStep('input'); return; }
      const bl = [...fdRaw.map(f=>(f.key_display_name||'').toLowerCase()), ...sfRaw.map(s=>(s.key_display_name||'').toLowerCase())].filter(Boolean);
      setKwData((kwR.group_by||[]).sort((a,b)=>b.count-a.count).filter(k=>!isBroad(k.key_display_name||'',bl)).slice(0,20).map((k,i)=>({name:k.key_display_name||k.key||'Unknown',count:k.count,fill:PAL[i%PAL.length]})));
      setSfData(sfRaw.map((s,i)=>({name:s.key_display_name||s.key,value:s.count,count:s.count,fill:PAL[i%PAL.length]})));
      setTab('keywords'); setStep('results');
    } catch { setErr('数据获取失败，请检查网络后重试。'); setStep('input'); }
  };
  const resetF1 = () => { setQuery(''); setSuggestions([]); setDetails(null); setKwData([]); setSfData([]); setStep('input'); setTab('keywords'); setErr(''); };
  const loadEx1 = () => { setQuery('Physical Review Letters'); setShowDrop(true); setTimeout(()=>doSearch('Physical Review Letters'),100); };

  /* ═══ F2: 选刊推荐（三级管道） ═══ */
  const handleFileUpload = (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => setDRefs(ev.target.result);
    reader.readAsText(file);
  };

  const analyzeDraft = async () => {
    const title = dTitle.trim();
    if (!title) return;
    setDErr('');

    /* 解析参考文献 */
    const rawText = dRefs.trim();
    const entries = rawText ? splitReferences(rawText) : [];
    const withDOI = [];
    const withoutDOI = [];
    for (const raw of entries) {
      const cleaned = preprocessEntry(raw);
      const dois = extractDOIs(cleaned);
      if (dois.length > 0) withDOI.push({ cleaned, dois });
      else withoutDOI.push({ cleaned });
    }
    const refTotal = withDOI.length + withoutDOI.length;

    setDStep('loading');
    setDProgress(0);
    setDProgressText('正在检索相似论文…');

    try {
      /* ──── Phase 0: 标题检索相似论文 ──── */
      const mainR = await fetch(`https://api.openalex.org/works?search=${encodeURIComponent(title)}&per_page=50`);
      const mainData = await mainR.json();
      const simWorks = mainData.results || [];
      if (simWorks.length === 0 && refTotal === 0) {
        setDErr('未找到相似文献，请尝试更具体的标题或添加参考文献。');
        setDStep('input'); return;
      }

      /* ──── Phase 1–3: 三级管道解析参考文献 ──── */
      const refWorks = [];
      let exactCount = 0, crossrefCount = 0, fuzzyCount = 0, failedCount = 0;
      let processed = 0;
      const totalTasks = refTotal;

      const tick = (text) => {
        processed++;
        if (totalTasks > 0) setDProgress(Math.round((processed / totalTasks) * 100));
        setDProgressText(text);
      };

      // Phase 1: DOI 精确
      for (let i = 0; i < withDOI.length; i++) {
        const label = `阶段 1/3：DOI 精确查询 ${i+1}/${withDOI.length}`;
        setDProgressText(label);
        let matched = false;
        for (const doi of withDOI[i].dois) {
          const data = await fetchOpenAlexByDOI(doi);
          if (data) { refWorks.push({ data, matchType: 'exact' }); exactCount++; matched = true; break; }
        }
        if (!matched) withoutDOI.push(withDOI[i]); // fallback 到下一阶段
        tick(label);
        if (i < withDOI.length - 1) await sleep(100);
      }

      // Phase 2: CrossRef bibliographic
      const crossrefPending = [];
      const phase2Items = withoutDOI.slice(withDOI.length); // 原始无DOI项
      const allNoDoi = [...withoutDOI]; // 包含DOI失败的
      // 重新收集：原始无DOI + DOI查询失败的
      const phase2Pool = [];
      // 已经在withoutDOI里了（原始无DOI在前，DOI失败push在后）
      // 但withDOI里DOI查询成功的不会进来，失败的push了
      // 所以 withoutDOI 现在包含了所有需要CrossRef的
      // 不对——withDOI失败的push进了withoutDOI，所以withoutDOI长度变了
      // 需要只处理还没处理过的
      const needCrossRef = withoutDOI.slice(0); // 原始withoutDOI + DOI失败的

      // 去掉已经DOI成功的，只留需要CrossRef的
      // 实际上withDOI失败才push到withoutDOI，成功的没有
      // 但原始withoutDOI的也在里面，且withDOI失败的append在后面
      // 简单做法：记录原始withoutDOI长度
      const origNoDoi = entries.length > 0 ? withoutDOI.length - (withDOI.length - exactCount) : 0;
      // 不对，我改了withoutDOI，逻辑混乱了。重构：

      // 重新来：不修改withoutDOI
      // 已经改了...算了，换个变量
      const doiFailed = [];

      // 上面的逻辑有问题，我重写Phase 1
      // 实际上上面push到withoutDOI是错的，我换用doiFailed
      // 但代码已经执行了...这是组件代码，我需要重新组织

      // OK 我直接收集所有需要CrossRef的
      const needCR = [];
      // withoutDOI 在push之前的原始内容 = entries中无DOI的
      // push进去的 = withDOI中DOI查询失败的
      // 但此时withoutDOI已被污染
      // 安全做法：遍历所有entries，排除已成功的
      const resolvedDois = new Set(refWorks.map(w => w.data.doi).filter(Boolean));

      for (let i = 0; i < entries.length; i++) {
        const cleaned = preprocessEntry(entries[i]);
        const dois = extractDOIs(cleaned);
        if (dois.length > 0) {
          // 检查是否已DOI成功
          let found = false;
          for (const doi of dois) {
            if (resolvedDois.has('https://doi.org/' + doi) || resolvedDois.has(doi)) { found = true; break; }
          }
          if (!found) needCR.push({ cleaned });
        } else {
          needCR.push({ cleaned });
        }
      }

      for (let i = 0; i < needCR.length; i++) {
        const label = `阶段 2/3：CrossRef 书目匹配 ${i+1}/${needCR.length}`;
        setDProgressText(label);
        const bibStr = needCR[i].cleaned;
        let matched = false;
        if (bibStr.length > 10) {
          const doi = await fetchCrossRefBiblio(bibStr);
          if (doi) {
            const data = await fetchOpenAlexByDOI(doi);
            if (data) { refWorks.push({ data, matchType: 'crossref' }); crossrefCount++; matched = true; }
            await sleep(80);
          }
        }
        if (!matched) crossrefPending.push(needCR[i]);
        tick(label);
        await sleep(150);
      }

      // Phase 3: OpenAlex title search 兜底
      for (let i = 0; i < crossrefPending.length; i++) {
        const label = `阶段 3/3：标题模糊检索 ${i+1}/${crossrefPending.length}`;
        setDProgressText(label);
        const q = extractTitleQuery(crossrefPending[i].cleaned);
        if (q.length > 10) {
          const data = await fetchOpenAlexBySearch(q);
          if (data) { refWorks.push({ data, matchType: 'fuzzy' }); fuzzyCount++; }
          else failedCount++;
        } else failedCount++;
        tick(label);
        if (i < crossrefPending.length - 1) await sleep(150);
      }

      setDMatchStats({ exact: exactCount, crossref: crossrefCount, fuzzy: fuzzyCount, failed: failedCount });

      /* ──── 聚合投票 ──── */
      setDProgressText('正在聚合投票…');
      const srcMap = {};
      const gKw = {}, gSf = {}, gFd = {};

      const extractTopics = w => {
        (w.keywords || []).forEach(k => { const n = k.display_name; if (n) gKw[n] = (gKw[n] || 0) + 1; });
        const sf = w.primary_topic?.subfield?.display_name;
        const fd = w.primary_topic?.field?.display_name;
        if (sf) gSf[sf] = (gSf[sf] || 0) + 1;
        if (fd) gFd[fd] = (gFd[fd] || 0) + 1;
      };

      const vote = (w, wt, matchType) => {
        const src = w.primary_location?.source;
        if (!src?.id || !src?.display_name) return false;
        if (src.type && src.type !== 'journal') return false;
        const sid = src.id;
        if (!srcMap[sid]) srcMap[sid] = { id: sid, name: src.display_name, issn_l: src.issn_l, count: 0, kw: {}, sf: {}, matchTypes: {} };
        srcMap[sid].count += wt;
        srcMap[sid].matchTypes[matchType] = (srcMap[sid].matchTypes[matchType] || 0) + 1;
        (w.keywords || []).forEach(k => { const n = k.display_name; if (n) srcMap[sid].kw[n] = (srcMap[sid].kw[n] || 0) + wt; });
        const sf = w.primary_topic?.subfield?.display_name;
        if (sf) srcMap[sid].sf[sf] = (srcMap[sid].sf[sf] || 0) + wt;
        return true;
      };

      let simEff = 0, refEff = 0;
      simWorks.forEach(w => { extractTopics(w); if (vote(w, 1, 'sim')) simEff++; });
      refWorks.forEach(({ data, matchType }) => { extractTopics(data); if (vote(data, 3, matchType)) refEff++; });

      const pool = simEff + refEff * 3;
      if (pool === 0) { setDErr('未找到有效期刊来源。'); setDStep('input'); return; }

      const broadNames = [...Object.keys(gSf), ...Object.keys(gFd)].map(s => s.toLowerCase());
      const filteredKw = Object.entries(gKw).sort((a, b) => b[1] - a[1]).filter(([k]) => !isBroad(k, broadNames)).slice(0, 10).map(([k, v]) => ({ name: k, count: v }));
      const topSf = Object.entries(gSf).sort((a, b) => b[1] - a[1]).slice(0, 5).map(([k, v]) => ({ name: k, count: v }));

      const top3 = Object.values(srcMap).sort((a, b) => b.count - a.count).slice(0, 3).map(s => ({
        ...s, confidence: s.count / pool,
        topKw: Object.entries(s.kw).sort((a, b) => b[1] - a[1]).slice(0, 6).map(([k]) => k),
        topSf: Object.entries(s.sf).sort((a, b) => b[1] - a[1])[0]?.[0] || null,
      }));

      const detailsArr = await Promise.all(top3.map(s => fetch(`https://api.openalex.org/sources/${s.id.replace('https://openalex.org/', '')}`).then(r => r.json()).catch(() => null)));
      top3.forEach((s, i) => { if (detailsArr[i]) s.det = detailsArr[i]; });

      setDRes({ simTotal: simWorks.length, simEff, refTotal, refResolved: exactCount + crossrefCount + fuzzyCount, refEff, pool, keywords: filteredKw, subfields: topSf, recs: top3 });
      setDStep('results');
    } catch (e) { setDErr('分析失败，请检查网络后重试。'); setDStep('input'); }
  };

  const resetF2 = () => { setDTitle(''); setDRefs(''); setDRes(null); setDStep('input'); setDErr(''); setDProgress(0); setDMatchStats({ exact:0,crossref:0,fuzzy:0,failed:0 }); };
  const loadEx2 = () => {
    setDTitle('Topological superconductivity in twisted bilayer graphene');
    setDRefs(`[1] Y. Cao, V. Fatemi, S. Fang et al., Unconventional superconductivity in magic-angle graphene superlattices, Nature 556, 43 (2018). doi:10.1038/nature26160
[2] Y. Cao, V. Fatemi, A. Demir et al., Correlated insulator behaviour at half-filling in magic-angle graphene superlattices, Nature 556, 80 (2018). doi:10.1038/nature26154
[3] M. Yankowitz et al., Tuning superconductivity in twisted bilayer graphene, Science 363, 1059 (2019).
[4] X. Lu et al., Superconductors, orbital magnets and correlated states in magic-angle bilayer graphene, Nature 574, 653 (2019).
[5] A. L. Sharpe et al., Emergent ferromagnetism near three-quarters filling in twisted bilayer graphene, Science 365, 605 (2019).`);
  };
  const gotoProfile = rec => { setMode('journal'); if (rec.det) analyzeJournal(rec.det); };

  /* ─── ref preview ─── */
  const getRefPreview = () => {
    if (!dRefs.trim()) return { total: 0, dois: 0, noDoi: 0 };
    const entries = splitReferences(dRefs);
    let doiCount = 0, noDoiCount = 0;
    for (const raw of entries) {
      const cleaned = preprocessEntry(raw);
      if (extractDOIs(cleaned).length > 0) doiCount++; else noDoiCount++;
    }
    return { total: entries.length, dois: doiCount, noDoi: noDoiCount };
  };
  const refPreview = dRefs.trim() ? getRefPreview() : { total: 0, dois: 0, noDoi: 0 };

  const matchLabel = (type) => {
    if (type === 'exact' || type === 'doi') return { text: 'DOI', cls: 'text-emerald-700 bg-emerald-50' };
    if (type === 'crossref') return { text: 'CrossRef', cls: 'text-blue-700 bg-blue-50' };
    if (type === 'fuzzy') return { text: '模糊', cls: 'text-amber-600 bg-amber-50' };
    return { text: '相似', cls: 'text-gray-500 bg-gray-50' };
  };

  /* ─── shared UI ─── */
  const CustomTip = ({ active, payload }) => { if (!active || !payload?.length) return null; const d = payload[0].payload; return <div className="bg-white border border-gray-200 rounded-xl px-3 py-2 shadow-lg text-xs"><p className="font-semibold text-gray-900 mb-0.5">{d.name}</p><p className="text-gray-500">{d.count ?? d.value} 篇</p></div>; };
  const YT = ({ x, y, payload }) => { const t = payload.value; return <text x={x} y={y} dy={4} textAnchor="end" fill="#374151" fontSize={11}>{t.length > 28 ? t.slice(0, 26) + '…' : t}</text>; };
  const Tag = ({ children, cls = 'bg-gray-100 text-gray-600' }) => <span className={`inline-block text-xs px-2 py-0.5 rounded-full ${cls}`}>{children}</span>;

  return (
    <div className="min-h-screen bg-gray-50">
      <div className="bg-white border-b border-gray-200">
        <div className="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-9 h-9 bg-teal-600 rounded-xl flex items-center justify-center shadow-sm"><BookOpen className="w-4 h-4 text-white" /></div>
            <div><h1 className="text-xl font-bold text-gray-900 tracking-tight">JournalTaste</h1><p className="text-xs text-gray-400">期刊选题图谱 · 智能选刊推荐</p></div>
          </div>
          <div className="flex bg-gray-100 rounded-xl p-0.5">
            {[['journal', '期刊图谱', BookOpen], ['draft', '选刊推荐', Target]].map(([k, l, Ic]) => (
              <button key={k} onClick={() => setMode(k)} className={`flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium transition-all ${mode === k ? 'bg-white text-teal-700 shadow-sm' : 'text-gray-500 hover:text-gray-700'}`}>
                <Ic className="w-3.5 h-3.5" />{l}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div className="max-w-4xl mx-auto px-4 py-8">
        <AnimatePresence mode="wait">

          {/* ═══════════════ F1: 期刊图谱 ═══════════════ */}
          {mode === 'journal' && (
            <motion.div key="f1" initial={{ opacity: 0, y: 16 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, y: -16 }}>
              <AnimatePresence mode="wait">
                {step === 'input' && (
                  <motion.div key="f1in" initial={{ opacity: 0, y: 16 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, y: -16 }}>
